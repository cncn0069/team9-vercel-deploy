        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "typeId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "삭제 성공" } }
      }
    },
    "/{teamId}/reviews": {
      "get": {
        "tags": ["Reviews"],
        "summary": "리뷰 목록",
        "parameters": [
          { "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "meetingId", "in": "query", "schema": { "type": "integer" } },
          { "name": "userId", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "리뷰 목록" } }
      }
    },
    "/{teamId}/reviews/statistics": {
      "get": {
        "tags": ["Reviews"],
        "summary": "리뷰 통계",
        "parameters": [{ "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "리뷰 통계" } }
      }
    },
    "/{teamId}/reviews/categories/statistics": {
      "get": {
        "tags": ["Reviews"],
        "summary": "카테고리별 리뷰 통계",
        "parameters": [{ "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "카테고리 통계" } }
      }
    },
    "/{teamId}/reviews/{reviewId}": {
      "get": {
        "tags": ["Reviews"],
        "summary": "리뷰 상세",
        "parameters": [
          { "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "reviewId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "리뷰 상세" } }
      },
      "patch": {
        "tags": ["Reviews"],
        "summary": "리뷰 수정",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "reviewId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "수정 성공" } }
      },
      "delete": {
        "tags": ["Reviews"],
        "summary": "리뷰 삭제",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "reviewId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "삭제 성공" } }
      }
    },
    "/{teamId}/favorites": {
      "get": {
        "tags": ["Favorites"],
        "summary": "찜한 모임 목록",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "찜 목록" } }
      }
    },
    "/{teamId}/favorites/count": {
      "get": {
        "tags": ["Favorites"],
        "summary": "찜 개수",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "찜 개수" } }
      }
    },
    "/{teamId}/posts/{postId}": {
      "get": {
        "tags": ["Posts"],
        "summary": "게시글 상세",
        "parameters": [
          { "name": "teamId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "postId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "게시글 상세" } }
      },
